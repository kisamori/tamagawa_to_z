    "### 1.2 地形データ（DEM）\n",
    "\n",
    "実際のプロジェクトでは、SRTM 1\" DEMデータを使用します。\n",
    "ここではデモ用の簡易的なデータを生成します。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# デモ用の地形データ（DEM）の生成\n",
    "def create_demo_dem(nx=200, ny=200):\n",
    "    \"\"\"デモ用のDEMデータを生成する関数\n",
    "    \n",
    "    簡易的な河川地形を持つDEMを生成します。\n",
    "    \n",
    "    Parameters\n",
    "    ----------\n",
    "    nx, ny : int\n",
    "        DEMの横・縦のグリッド数\n",
    "        \n",
    "    Returns\n",
    "    -------\n",
    "    dem : numpy.ndarray\n",
    "        生成されたDEM\n",
    "    \"\"\"\n",
    "    # 乱数シードを固定（再現性のため）\n",
    "    np.random.seed(42)\n",
    "    \n",
    "    # 基本的な傾斜地形\n",
    "    x = np.linspace(0, 1, nx)\n",
    "    y = np.linspace(0, 1, ny)\n",
    "    X, Y = np.meshgrid(x, y)\n",
    "    \n",
    "    # 傾斜（上流から下流へ）\n",
    "    slope = 10 * (1 - X)\n",
    "    \n",
    "    # 現在の河川チャネル\n",
    "    channel = 2 * np.exp(-100 * (Y - 0.5 + 0.1 * np.sin(10 * X))**2)\n",
    "    \n",
    "    # 古河道（過去の河川経路）\n",
    "    old_channel1 = 1.5 * np.exp(-100 * (Y - 0.7 + 0.05 * np.sin(8 * X))**2)\n",
    "    old_channel2 = 1.0 * np.exp(-120 * (Y - 0.3 + 0.08 * np.cos(6 * X))**2)\n",
    "    \n",
    "    # ノイズ追加\n",
    "    noise = 0.2 * np.random.rand(ny, nx)\n",
    "    \n",
    "    # DEMの合成（高い値ほど標高が低い）\n",
    "    dem = slope - channel - old_channel1 - old_channel2 + noise\n",
    "    \n",
    "    # 正規化（0-10mの範囲に）\n",
    "    dem = 10 * (dem - dem.min()) / (dem.max() - dem.min())\n",
    "    \n",
    "    return dem\n",
    "\n",
    "# DEMの生成\n",
    "dem = create_demo_dem(200, 200)\n",
    "\n",
    "# 可視化\n",
    "plt.figure(figsize=(10, 8))\n",
    "plt.imshow(dem, cmap='terrain')\n",
    "plt.colorbar(label='標高 (m)')\n",
    "plt.title('デモ用DEM - 現在の河川と古河道を含む')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
