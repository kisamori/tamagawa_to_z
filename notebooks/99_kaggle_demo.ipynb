    "## 2. 多言語トポニム解析（System-A）\n",
    "\n",
    "地名（トポニム）を解析して、水に関連する地名を抽出・分類します。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# 地名の前処理\n",
    "def preprocess_toponyms(toponyms_gdf):\n",
    "    \"\"\"地名データを前処理する関数\n",
    "    \n",
    "    Parameters\n",
    "    ----------\n",
    "    toponyms_gdf : geopandas.GeoDataFrame\n",
    "        地名データ\n",
    "        \n",
    "    Returns\n",
    "    -------\n",
    "    processed_gdf : geopandas.GeoDataFrame\n",
    "        前処理済みの地名データ\n",
    "    \"\"\"\n",
    "    # コピーを作成\n",
    "    processed_gdf = toponyms_gdf.copy()\n",
    "    \n",
    "    # 正規化関数\n",
    "    def normalize_toponym(name):\n",
    "        # アクセント除去と小文字化\n",
    "        normalized = unidecode.unidecode(name.lower())\n",
    "        # 英数字とスペース、ハイフン以外を空白に置換\n",
    "        normalized = re.sub(r'[^a-z0-9\\s-]', ' ', normalized)\n",
    "        # 余分な空白を削除\n",
    "        normalized = re.sub(r'\\s+', ' ', normalized).strip()\n",
    "        return normalized\n",
    "    \n",
    "    # 正規化を適用\n",
    "    processed_gdf['normalized_name'] = processed_gdf['name'].apply(normalize_toponym)\n",
    "    \n",
    "    # 水関連語彙のシードリスト（ポルトガル語）\n",
    "    water_seeds = [\n",
    "        \"rio\", \"igarape\", \"lago\", \"parana\", \"cachoeira\", \n",
    "        \"corrego\", \"lagoa\", \"canal\", \"baia\", \"represa\"\n",
    "    ]\n",
    "    \n",
    "    # 簡易的な水関連度スコアの計算\n",
    "    def calculate_water_score(name):\n",
    "        name_parts = name.split()\n",
    "        for part in name_parts:\n",
    "            if part in water_seeds:\n",
    "                return 1.0  # 完全一致\n",
    "        \n",
    "        # 部分一致\n",
    "        for seed in water_seeds:\n",
    "            if seed in name:\n",
    "                return 0.8\n",
    "        \n",
    "        # 特徴タイプによる判定\n",
    "        water_features = ['river', 'stream', 'lake', 'channel', 'waterfall']\n",
    "        feature_type = processed_gdf.loc[processed_gdf['normalized_name'] == name, 'feature_type'].values[0]\n",
    "        if feature_type in water_features:\n",
    "            return 0.9\n",
    "        \n",
    "        return 0.1  # デフォルト（水関連度低）\n",
    "    \n",
    "    # 水関連度スコアの計算\n",
    "    processed_gdf['water_score'] = processed_gdf['normalized_name'].apply(calculate_water_score)\n",
    "    \n",
    "    return processed_gdf\n",
    "\n",
    "# 地名の前処理\n",
    "processed_toponyms = preprocess_toponyms(toponyms_gdf)\n",
    "\n",
    "# 結果の表示\n",
    "pd.DataFrame({\n",
    "    'name': processed_toponyms['name'],\n",
    "    'normalized': processed_toponyms['normalized_name'],\n",
    "    'feature_type': processed_toponyms['feature_type'],\n",
    "    'water_score': processed_toponyms['water_score']\n",
    "}).sort_values('water_score', ascending=False)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 2.1 水関連地名の確率マップ生成\n",
    "\n",
    "地名の水関連度をもとに、空間上の確率マップ（`Pwater(x)` ラスター）を生成します。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# 水関連地名の確率マップ生成\n",
    "def create_toponym_probability_map(toponyms_gdf, dem_shape, buffer_radius=10):\n",
    "    \"\"\"地名の水関連度に基づく確率マップを生成する関数\n",
    "    \n",
    "    Parameters\n",
    "    ----------\n",
    "    toponyms_gdf : geopandas.GeoDataFrame\n",
    "        地名データ（水関連度スコア付き）\n",
    "    dem_shape : tuple\n",
    "        出力ラスターの形状 (height, width)\n",
    "    buffer_radius : float\n",
    "        バッファ半径（ピクセル単位）\n",
    "        \n",
    "    Returns\n",
    "    -------\n",
    "    prob_map : numpy.ndarray\n",
    "        水関連確率マップ\n",
    "    \"\"\"\n",
    "    # 出力ラスターの初期化\n",
    "    ny, nx = dem_shape\n",
    "    prob_map = np.zeros((ny, nx))\n",
    "    \n",
    "    # 地理座標系から画像座標系への変換\n",
    "    # 簡易的な変換（実際はもっと正確な変換が必要）\n",
    "    min_lon = toponyms_gdf['lon'].min()\n",
    "    max_lon = toponyms_gdf['lon'].max()\n",
    "    min_lat = toponyms_gdf['lat'].min()\n",
    "    max_lat = toponyms_gdf['lat'].max()\n",
    "    \n",
    "    def geo_to_pixel(lon, lat):\n",
    "        x = int((lon - min_lon) / (max_lon - min_lon) * (nx - 1))\n",
    "        y = int((max_lat - lat) / (max_lat - min_lat) * (ny - 1))  # 緯度は反転\n",
    "        return x, y\n",
    "    \n",
    "    # 各地名ポイントの影響を追加\n",
    "    for idx, row in toponyms_gdf.iterrows():\n",
    "        x, y = geo_to_pixel(row['lon'], row['lat'])\n",
    "        \n",
    "        # 有効範囲内のみ処理\n",
    "        if 0 <= x < nx and 0 <= y < ny:\n",
    "            # バッファ領域の生成（ガウシアンカーネル）\n",
    "            y_indices, x_indices = np.ogrid[-buffer_radius:buffer_radius+1, -buffer_radius:buffer_radius+1]\n",
    "            mask = x_indices**2 + y_indices**2 <= buffer_radius**2\n",
    "            \n",
    "            # バッファ領域内の各ピクセルに水関連度を加算\n",
    "            for dy in range(-buffer_radius, buffer_radius+1):\n",
    "                for dx in range(-buffer_radius, buffer_radius+1):\n",
    "                    if mask[dy+buffer_radius, dx+buffer_radius]:\n",
    "                        py, px = y + dy, x + dx\n",
    "                        if 0 <= px < nx and 0 <= py < ny:\n",
    "                            # 距離に応じて減衰\n",
    "                            distance = np.sqrt(dx**2 + dy**2)\n",
    "                            weight = row['water_score'] * np.exp(-0.5 * (distance / (buffer_radius/2))**2)\n",
    "                            prob_map[py, px] = max(prob_map[py, px], weight)  # 最大値を採用\n",
    "    \n",
    "    # スムージング\n",
    "    prob_map = gaussian_filter(prob_map, sigma=buffer_radius/3)\n",
    "    \n",
    "    # 0-1の範囲に正規化\n",
    "    if prob_map.max() > 0:\n",
    "        prob_map = prob_map / prob_map.max()\n",
    "    \n",
    "    return prob_map\n",
    "\n",
    "# 水関連地名の確率マップ生成\n",
    "toponym_prob_map = create_toponym_probability_map(processed_toponyms, dem.shape, buffer_radius=15)\n",
    "\n",
    "# 可視化\n",
    "plt.figure(figsize=(12, 10))\n",
    "\n",
    "# 確率マップの表示\n",
    "plt.imshow(toponym_prob_map, cmap='Blues', alpha=0.7)\n",
    "plt.colorbar(label='Pwater(x) - 水関連確率')\n",
    "\n",
    "# 地名ポイントの表示\n",
    "water_toponyms = processed_toponyms[processed_toponyms['water_score'] >= 0.8]\n",
    "non_water_toponyms = processed_toponyms[processed_toponyms['water_score'] < 0.8]\n",
    "\n",
    "# 地理座標から画像座標への変換\n",
    "min_lon = processed_toponyms['lon'].min()\n",
    "max_lon = processed_toponyms['lon'].max()\n",
    "min_lat = processed_toponyms['lat'].min()\n",
    "max_lat = processed_toponyms['lat'].max()\n",
    "nx, ny = dem.shape[1], dem.shape[0]\n",
    "\n",
    "def plot_point(lon, lat, color, marker, label=None):\n",
    "    x = (lon - min_lon) / (max_lon - min_lon) * (nx - 1)\n",
    "    y = (max_lat - lat) / (max_lat - min_lat) * (ny - 1)  # 緯度は反転\n",
    "    plt.plot(x, y, color=color, marker=marker, markersize=10, label=label)\n",
    "\n",
    "# 水関連地名\n",
    "for idx, row in water_toponyms.iterrows():\n",
    "    plot_point(row['lon'], row['lat'], 'blue', 'o', label='水関連地名' if idx == water_toponyms.index[0] else None)\n",
    "\n",
    "# 非水関連地名\n",
    "for idx, row in non_water_toponyms.iterrows():\n",
    "    plot_point(row['lon'], row['lat'], 'red', 'x', label='非水関連地名' if idx == non_water_toponyms.index[0] else None)\n",
    "\n",
    "plt.legend()\n",
    "plt.title('水関連地名の確率マップ (Pwater(x))')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. 統合解析: 古河道確率マップの生成\n",
    "\n",
    "水関連地名の確率マップ、水域履歴データ、DEMを統合して、古河道の存在確率マップを生成します。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# 古河道確率マップの生成\n",
    "def create_paleochannel_probability_map(dem, water_history, toponym_prob_map, \n",
    "                                        w_dem=0.3, w_history=0.4, w_toponym=0.3):\n",
    "    \"\"\"古河道の存在確率マップを生成する関数\n",
    "    \n",
    "    Parameters\n",
    "    ----------\n",
    "    dem : numpy.ndarray\n",
    "        標高データ\n",
    "    water_history : numpy.ndarray\n",
    "        水域履歴データ\n",
    "    toponym_prob_map : numpy.ndarray\n",
    "        水関連地名の確率マップ\n",
    "    w_dem, w_history, w_toponym : float\n",
