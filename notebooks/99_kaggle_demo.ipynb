    "### 1.3 水域履歴データ\n",
    "\n",
    "実際のプロジェクトでは、JRC Global Surface Waterデータを使用します。\n",
    "ここではデモ用の簡易的なデータを生成します。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# デモ用の水域履歴データの生成\n",
    "def create_demo_water_history(dem, noise_level=0.2):\n",
    "    \"\"\"デモ用の水域履歴データを生成する関数\n",
    "    \n",
    "    DEMに基づいて、過去の水域の出現確率を生成します。\n",
    "    \n",
    "    Parameters\n",
    "    ----------\n",
    "    dem : numpy.ndarray\n",
    "        標高データ\n",
    "    noise_level : float\n",
    "        ノイズレベル\n",
    "        \n",
    "    Returns\n",
    "    -------\n",
    "    water_prob : numpy.ndarray\n",
    "        水域出現確率\n",
    "    \"\"\"\n",
    "    ny, nx = dem.shape\n",
    "    \n",
    "    # 標高の正規化（低いほど1に近い）\n",
    "    normalized_dem = (dem.max() - dem) / (dem.max() - dem.min())\n",
    "    \n",
    "    # 水域出現確率（低い標高ほど水域になりやすい）\n",
    "    water_prob = normalized_dem**2  # 二乗して差を強調\n",
    "    \n",
    "    # ノイズ追加\n",
    "    np.random.seed(43)  # 再現性のため\n",
    "    noise = noise_level * (np.random.rand(ny, nx) - 0.5)\n",
    "    water_prob += noise\n",
    "    \n",
    "    # 0-1の範囲に収める\n",
    "    water_prob = np.clip(water_prob, 0, 1)\n",
    "    \n",
    "    return water_prob\n",
    "\n",
    "# 水域履歴データの生成\n",
    "water_history = create_demo_water_history(dem)\n",
    "\n",
    "# 可視化\n",
    "plt.figure(figsize=(10, 8))\n",
    "plt.imshow(water_history, cmap='Blues')\n",
    "plt.colorbar(label='水域出現確率')\n",
    "plt.title('デモ用水域履歴データ (1984-2021)')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
