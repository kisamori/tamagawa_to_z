   "source": [
    "### 1.2 境界条件の設定\n",
    "\n",
    "モデルの境界条件を設定します。上流端の流量と下流端の水位を設定します。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# 境界条件の設定\n",
    "def create_boundary_conditions(duration_days=10, timestep_hours=1):\n",
    "    \"\"\"境界条件を生成する関数\n",
    "    \n",
    "    Parameters\n",
    "    ----------\n",
    "    duration_days : int\n",
    "        シミュレーション期間（日）\n",
    "    timestep_hours : int\n",
    "        時間ステップ（時間）\n",
    "        \n",
    "    Returns\n",
    "    -------\n",
    "    time : numpy.ndarray\n",
    "        時間配列\n",
    "    upstream_q : numpy.ndarray\n",
    "        上流端の流量 (m3/s)\n",
    "    downstream_h : numpy.ndarray\n",
    "        下流端の水位 (m)\n",
    "    \"\"\"\n",
    "    # 時間配列\n",
    "    start_time = datetime(2025, 1, 1)\n",
    "    time_steps = int(duration_days * 24 / timestep_hours)\n",
    "    time = [start_time + timedelta(hours=i*timestep_hours) for i in range(time_steps)]\n",
    "    \n",
    "    # 上流端の流量（洪水波形）\n",
    "    base_flow = 100  # m3/s\n",
    "    peak_flow = 300  # m3/s\n",
    "    t = np.linspace(0, 2*np.pi, time_steps)\n",
    "    upstream_q = base_flow + peak_flow * np.sin(t/5)**2\n",
    "    \n",
    "    # 下流端の水位（潮汐変動）\n",
    "    mean_level = 2.0  # m\n",
    "    tidal_range = 0.5  # m\n",
    "    downstream_h = mean_level + tidal_range * np.sin(t)\n",
    "    \n",
    "    return time, upstream_q, downstream_h\n",
    "\n",
    "# 境界条件の生成\n",
    "time, upstream_q, downstream_h = create_boundary_conditions()\n",
    "\n",
    "# 可視化\n",
    "fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(10, 8), sharex=True)\n",
    "\n",
    "# 上流端の流量\n",
    "ax1.plot(time, upstream_q, 'b-')\n",
    "ax1.set_ylabel('流量 (m³/s)')\n",
    "ax1.set_title('上流端境界条件')\n",
    "ax1.grid(True)\n",
    "\n",
    "# 下流端の水位\n",
    "ax2.plot(time, downstream_h, 'r-')\n",
    "ax2.set_ylabel('水位 (m)')\n",
    "ax2.set_title('下流端境界条件')\n",
    "ax2.set_xlabel('時間')\n",
    "ax2.grid(True)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
