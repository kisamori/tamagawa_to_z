  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. フェーズA: 水理学データ同化（EnKF）\n",
    "\n",
    "アンサンブルカルマンフィルタ（EnKF）を用いた水理学データ同化を実行します。\n",
    "実際のプロジェクトでは、OpenDAとDelft3D-FMを連携させて実行します。\n",
    "ここではデモ用の簡易的なシミュレーションを行います。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# 簡易的なEnKFシミュレーション\n",
    "def run_demo_enkf(dem, ensemble_size=50):\n",
    "    \"\"\"簡易的なEnKFシミュレーションを実行する関数\n",
    "    \n",
    "    Parameters\n",
    "    ----------\n",
    "    dem : numpy.ndarray\n",
    "        標高データ\n",
    "    ensemble_size : int\n",
    "        アンサンブルサイズ\n",
    "        \n",
    "    Returns\n",
    "    -------\n",
    "    parameter_estimates : dict\n",
    "        パラメータの推定値\n",
    "    water_depth : numpy.ndarray\n",
    "        水深の推定値\n",
    "    \"\"\"\n",
    "    # 真のパラメータ値（実際のプロジェクトでは未知）\n",
    "    true_params = {\n",
    "        'Manning_n': 0.035,  # Manning粗度係数\n",
    "        'Ks': 5e-5,          # 透水係数\n",
    "        'Q_factor': 1.0      # 流量係数\n",
    "    }\n",
    "    \n",
    "    # パラメータのアンサンブル生成\n",
    "    np.random.seed(42)  # 再現性のため\n",
    "    \n",
    "    # Manning粗度係数（対数正規分布）\n",
    "    manning_n = np.random.lognormal(np.log(0.035), 0.25, ensemble_size)\n",
    "    \n",
    "    # 透水係数（一様分布）\n",
    "    ks = np.random.uniform(1e-6, 1e-4, ensemble_size)\n",
    "    \n",
    "    # 流量係数（正規分布）\n",
    "    q_factor = np.random.normal(1.0, 0.2, ensemble_size)\n",
    "    q_factor = np.clip(q_factor, 0.5, 1.5)  # 範囲制限\n",
    "    \n",
    "    # 簡易的なシミュレーション（実際はDelft3D-FMを実行）\n",
    "    # ここでは単純な関数で水深を計算\n",
    "    ny, nx = dem.shape\n",
    "    water_depth = np.zeros((ensemble_size, ny, nx))\n",
    "    \n",
    "    for i in range(ensemble_size):\n",
    "        # 簡易的な水深計算（実際はもっと複雑な水理計算）\n",
    "        # 低い標高ほど水深が大きくなるように\n",
    "        normalized_dem = (dem.max() - dem) / (dem.max() - dem.min())\n",
    "        \n",
    "        # パラメータの影響を模擬\n",
    "        param_effect = (manning_n[i] / true_params['Manning_n']) * \\\n",
    "                       (ks[i] / true_params['Ks']) * \\\n",
    "                       (q_factor[i] / true_params['Q_factor'])\n",
    "        \n",
    "        # 水深計算（単純化）\n",
    "        water_depth[i] = 3.0 * normalized_dem * param_effect + 0.1 * np.random.randn(ny, nx)\n",
    "        water_depth[i] = np.maximum(water_depth[i], 0)  # 負の水深を0に\n",
    "    \n",
    "    # 観測データの生成（実際のプロジェクトでは実測データを使用）\n",
    "    # 真のパラメータに近いものを「観測」とする\n",
    "    normalized_dem = (dem.max() - dem) / (dem.max() - dem.min())\n",
    "    true_water_depth = 3.0 * normalized_dem + 0.05 * np.random.randn(ny, nx)\n",
    "    true_water_depth = np.maximum(true_water_depth, 0)\n",
    "    \n",
    "    # 観測点の選択（実際はANA観測所やSentinel-2画像に対応）\n",
    "    obs_points = np.random.choice(ny * nx, 10, replace=False)  # 10観測点\n",
    "    obs_y, obs_x = np.unravel_index(obs_points, (ny, nx))\n",
    "    \n",
    "    # 観測値\n",
    "    obs_values = true_water_depth[obs_y, obs_x]\n",
    "    \n",
    "    # EnKFの実行（簡易版）\n",
    "    # 実際はOpenDAが行う処理\n",
    "    \n",
    "    # アンサンブル平均\n",
    "    mean_water_depth = np.mean(water_depth, axis=0)\n",
    "    \n",
    "    # 観測点での予測値\n",
    "    predicted_values = np.array([water_depth[i, obs_y, obs_x] for i in range(ensemble_size)])\n",
    "    \n",
    "    # 観測誤差（仮定）\n",
    "    obs_error = 0.1\n",
    "    \n",
    "    # カルマンゲインの計算（簡易版）\n",
    "    # 実際はもっと複雑な計算\n",
    "    innovation = obs_values - np.mean(predicted_values, axis=0)\n",
    "    \n",
    "    # アンサンブルの更新\n",
    "    for i in range(ensemble_size):\n",
    "        # 観測点での更新\n",
    "        for j in range(len(obs_y)):\n",
    "            y, x = obs_y[j], obs_x[j]\n",
    "            water_depth[i, y, x] += 0.7 * (obs_values[j] - predicted_values[i, j])\n",
    "        \n",
    "        # 周辺への伝播（簡易版）\n",
    "        # 実際はもっと物理的に正確な方法で\n",
    "        water_depth[i] = gaussian_filter(water_depth[i], sigma=1.0)\n",
    "    \n",
    "    # パラメータの更新（簡易版）\n",
    "    # 実際はもっと複雑な計算\n",
    "    rmse_before = np.sqrt(np.mean((mean_water_depth[obs_y, obs_x] - obs_values)**2))\n",
    "    mean_water_depth_after = np.mean(water_depth, axis=0)\n",
    "    rmse_after = np.sqrt(np.mean((mean_water_depth_after[obs_y, obs_x] - obs_values)**2))\n",
    "    \n",
    "    # パラメータの調整係数\n",
    "    adjust_factor = rmse_before / (rmse_after + 1e-10)\n",
    "    \n",
    "    # パラメータの更新\n",
    "    manning_n *= adjust_factor\n",
    "    ks *= adjust_factor\n",
    "    \n",
    "    # 結果の集約\n",
    "    parameter_estimates = {\n",
    "        'Manning_n': np.mean(manning_n),\n",
    "        'Manning_n_std': np.std(manning_n),\n",
    "        'Ks': np.mean(ks),\n",
    "        'Ks_std': np.std(ks),\n",
    "        'Q_factor': np.mean(q_factor),\n",
    "        'Q_factor_std': np.std(q_factor)\n",
    "    }\n",
    "    \n",
    "    return parameter_estimates, np.mean(water_depth, axis=0)\n",
    "\n",
    "# scipy.ndimageをインポート（gaussian_filter用）\n",
    "from scipy.ndimage import gaussian_filter\n",
    "\n",
    "# EnKFの実行\n",
    "parameter_estimates, water_depth = run_demo_enkf(dem)\n",
    "\n",
    "# 結果の表示\n",
    "print(\"パラメータ推定値:\")\n",
    "for param, value in parameter_estimates.items():\n",
    "    print(f\"{param}: {value:.6f}\")\n",
    "\n",
    "# 水深の可視化\n",
    "plt.figure(figsize=(10, 8))\n",
    "plt.imshow(water_depth, cmap='Blues')\n",
    "plt.colorbar(label='水深 (m)')\n",
    "plt.title('EnKFによる水深推定結果')\n",
    "plt.tight_layout()\n",
    "plt.show()"
