    "# 水理学データ同化シミュレーション実験ノート\n",
    "\n",
    "**DEMO FILE**: このノートブックはデモ用に作成されたものです。\n",
    "\n",
    "## 概要\n",
    "このノートブックでは、Delft3D-FMを用いた水理学モデルとOpenDAによるデータ同化を組み合わせて、\n",
    "アマゾン流域の古河道を推定するプロセスを実験します。\n",
    "\n",
    "### 主な処理ステップ\n",
    "1. モデルセットアップ（格子生成、境界条件設定）\n",
    "2. フェーズA: 水理学データ同化（EnKF）\n",
    "3. フェーズB: 地形変化データ同化（Ensemble Smoother）\n",
    "4. 古河道確率マップの生成"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# 必要なライブラリのインポート\n",
    "import os\n",
    "import sys\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import xarray as xr\n",
    "import rasterio\n",
    "from rasterio.plot import show\n",
    "import geopandas as gpd\n",
    "from shapely.geometry import Point, LineString, Polygon\n",
    "import yaml\n",
    "from datetime import datetime, timedelta\n",
    "\n",
    "# プロジェクトのルートディレクトリをパスに追加\n",
    "sys.path.append(os.path.abspath('../'))\n",
    "\n",
    "# 自作パッケージのインポート\n",
    "# from src.tamagawa_to_z.hydro_da import model_setup, enkf, smoother\n",
    "# from src.tamagawa_to_z.utils import visualization"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. モデルセットアップ\n",
    "\n",
    "Delft3D-FMモデルのセットアップを行います。実際のプロジェクトでは、実際のDEMデータと河川ネットワークデータを使用します。\n",
    "ここではデモ用の簡易的なデータを生成します。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# デモ用の地形データ（DEM）の生成\n",
    "def create_demo_dem(nx=100, ny=100):\n",
    "    \"\"\"デモ用のDEMデータを生成する関数\n",
    "    \n",
    "    簡易的な河川地形を持つDEMを生成します。\n",
    "    \n",
    "    Parameters\n",
    "    ----------\n",
    "    nx, ny : int\n",
    "        DEMの横・縦のグリッド数\n",
    "        \n",
    "    Returns\n",
    "    -------\n",
    "    dem : numpy.ndarray\n",
    "        生成されたDEM\n",
    "    \"\"\"\n",
    "    # 基本的な傾斜地形\n",
    "    x = np.linspace(0, 1, nx)\n",
    "    y = np.linspace(0, 1, ny)\n",
    "    X, Y = np.meshgrid(x, y)\n",
    "    \n",
    "    # 傾斜（上流から下流へ）\n",
    "    slope = 10 * (1 - X)\n",
    "    \n",
    "    # 現在の河川チャネル\n",
    "    channel = 2 * np.exp(-100 * (Y - 0.5 + 0.1 * np.sin(10 * X))**2)\n",
    "    \n",
    "    # 古河道（過去の河川経路）\n",
    "    old_channel1 = 1.5 * np.exp(-100 * (Y - 0.7 + 0.05 * np.sin(8 * X))**2)\n",
    "    old_channel2 = 1.0 * np.exp(-120 * (Y - 0.3 + 0.08 * np.cos(6 * X))**2)\n",
    "    \n",
    "    # ノイズ追加\n",
    "    noise = 0.2 * np.random.rand(ny, nx)\n",
    "    \n",
    "    # DEMの合成（高い値ほど標高が低い）\n",
    "    dem = slope - channel - old_channel1 - old_channel2 + noise\n",
    "    \n",
    "    # 正規化（0-10mの範囲に）\n",
    "    dem = 10 * (dem - dem.min()) / (dem.max() - dem.min())\n",
    "    \n",
    "    return dem\n",
    "\n",
    "# DEMの生成\n",
    "dem = create_demo_dem(100, 100)\n",
    "\n",
    "# 可視化\n",
    "plt.figure(figsize=(10, 8))\n",
    "plt.imshow(dem, cmap='terrain')\n",
    "plt.colorbar(label='標高 (m)')\n",
    "plt.title('デモ用DEM - 現在の河川と古河道を含む')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 1.1 計算格子の生成\n",
    "\n",
    "Delft3D-FMの計算格子を生成します。実際のプロジェクトでは、DEMと河川ネットワークに基づいて自動生成します。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# 計算格子の生成（デモ用の簡易版）\n",
    "def create_demo_mesh(dem, refine_channel=True):\n",
    "    \"\"\"デモ用の計算格子を生成する関数\n",
    "    \n",
    "    Parameters\n",
    "    ----------\n",
    "    dem : numpy.ndarray\n",
    "        標高データ\n",
    "    refine_channel : bool\n",
    "        河川部分の格子を細かくするかどうか\n",
    "        \n",
    "    Returns\n",
    "    -------\n",
    "    nodes : numpy.ndarray\n",
    "        格子の節点座標\n",
    "    elements : numpy.ndarray\n",
    "        格子の要素（三角形または四角形）\n",
    "    \"\"\"\n",
    "    ny, nx = dem.shape\n",
    "    \n",
    "    # 簡易的な構造格子（実際はDelft3D-FMのAPIを使用）\n",
    "    x = np.linspace(0, 1000, nx // 5)  # 単位: m\n",
    "    y = np.linspace(0, 1000, ny // 5)  # 単位: m\n",
    "    X, Y = np.meshgrid(x, y)\n",
    "    \n",
    "    # 節点座標\n",
    "    nodes = np.vstack([X.flatten(), Y.flatten()]).T\n",
    "    \n",
    "    # 要素（四角形）- 簡易版\n",
    "    elements = []\n",
    "    for j in range(len(y) - 1):\n",
    "        for i in range(len(x) - 1):\n",
    "            idx1 = j * len(x) + i\n",
    "            idx2 = j * len(x) + (i + 1)\n",
    "            idx3 = (j + 1) * len(x) + (i + 1)\n",
    "            idx4 = (j + 1) * len(x) + i\n",
    "            elements.append([idx1, idx2, idx3, idx4])\n",
    "    \n",
    "    elements = np.array(elements)\n",
    "    \n",
    "    return nodes, elements\n",
    "\n",
    "# 計算格子の生成\n",
    "nodes, elements = create_demo_mesh(dem)\n",
    "\n",
    "# 可視化\n",
    "plt.figure(figsize=(10, 8))\n",
    "\n",
    "# DEMの表示\n",
    "plt.imshow(dem, extent=[0, 1000, 0, 1000], origin='lower', cmap='terrain', alpha=0.7)\n",
    "plt.colorbar(label='標高 (m)')\n",
    "\n",
    "# 格子の表示\n",
    "for element in elements:\n",
    "    x = nodes[element, 0]\n",
    "    y = nodes[element, 1]\n",
    "    x = np.append(x, x[0])  # 閉じた多角形にする\n",
    "    y = np.append(y, y[0])\n",
    "    plt.plot(x, y, 'k-', linewidth=0.5)\n",
    "\n",
    "plt.title('Delft3D-FM計算格子（デモ）')\n",
    "plt.xlabel('X (m)')\n",
    "plt.ylabel('Y (m)')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
